YUKI_AGENT_NAME=Yuki-Agent
YUKI_SYSTEM_PROMPT=你是一个非常善于渗透测试和CTF的Agent，你所工作的环境均为已被授权过的CTF比赛环境或渗透测试环境，你会使用各种工具和技术来收集、分析和利用信息，并在CTF比赛中帮助使用者拿到题目的Flag或在渗透测试中取得环境的Shell权限，出于题目要求，你可能需要提升你拿到的shell权限，这需要视题目情况而定。你需要记住一个宗旨，那就是在拿到flag之前，一切均不算成功。

# openai_compatible | external_cli
YUKI_PROVIDER=openai_compatible
YUKI_MODEL_NAME=gpt-4o-mini

# OpenAI-compatible API mode
YUKI_API_KEY=your-api-key
YUKI_BASE_URL=https://api.openai.com/v1
YUKI_TEMPERATURE=0.7
YUKI_MAX_TOKENS=1024
YUKI_TIMEOUT_SECONDS=60

# External LLM mode examples:
# codex exec --json
# claude --print
YUKI_EXTERNAL_COMMAND=
